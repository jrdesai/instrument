{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "allow-base64",
    "allow-url-encoder",
    "allow-html-entity",
    "allow-hex-converter",
    "allow-md5",
    "allow-sha256",
    "allow-sha512",
    "allow-uuid",
    "allow-ulid",
    "allow-api-key"
  ]
}
