{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(cargo *)",
      "Bash(pnpm *)",
      "Bash(ls *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Read(public/wasm-pkg/**)",
      "Read(src-core/target/**)",
      "Read(src-tauri/target/**)",
      "Read(node_modules/**)",
      "Read(dist/**)",
      "Read(src/wasm-pkg/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command'); echo \"$cmd\" | grep -q 'git push' || exit 0; cd /Users/jigardesai/Code/Projects/instrument && pnpm run typecheck",
            "timeout": 60,
            "statusMessage": "Running typecheck before push..."
          }
        ]
      }
    ]
  }
}
