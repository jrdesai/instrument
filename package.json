{
  "name": "instrument",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "node scripts/tauri-build.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:wasm": "wasm-pack build src-core/instrument-web --target web --out-dir ../../public/wasm-pkg",
    "build:web": "pnpm run build:wasm && vite build --mode web",
    "build:cli-sidecar": "node scripts/build-cli-sidecar.js",
    "build:cli": "cargo build --release --manifest-path src-core/Cargo.toml -p instrument-cli",
    "install:cli": "cargo install --path src-core/instrument-cli --force",
    "test:rust": "cargo test --manifest-path src-core/Cargo.toml",
    "test:rust:core": "cargo test --manifest-path src-core/Cargo.toml -p instrument-core",
    "test:ts": "vitest run",
    "test:watch": "vitest",
    "test:all": "pnpm run test:rust && pnpm run test:ts",
    "lint": "eslint src/",
    "gen:types": "cargo run --manifest-path src-core/Cargo.toml -p instrument-core --bin export_types --features ts-export",
    "typecheck": "pnpm run gen:types && tsc --noEmit",
    "check:pure": "grep -r 'std::fs\\|tauri\\|tokio' src-core/instrument-core/src/ && echo 'PURITY VIOLATION' || echo 'instrument-core is pure'",
    "gen:og-image": "node scripts/generate-og-image.mjs",
    "gen:pwa-icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "immer": "^11.1.4",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.2",
    "prettier": "^3.8.3",
    "prismjs": "^1.29.0",
    "react": "^19.2.5",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "use-debounce": "^10.1.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.3",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.0.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
