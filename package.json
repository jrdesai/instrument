{
  "name": "instrument",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
  "dev":        "tauri dev",
  "build":      "tauri build",
  "preview":    "vite preview",
  "tauri":      "tauri",
  "build:wasm": "wasm-pack build src-core/instrument-web --target web --out-dir ../../src/wasm-pkg",
  "build:web":  "pnpm run build:wasm && vite build --mode web",
  "test:rust":  "cargo test --manifest-path src-core/Cargo.toml",
  "test:rust:core": "cargo test --manifest-path src-core/Cargo.toml -p instrument-core",
  "test:ts":    "vitest run",
  "test:watch": "vitest",
  "test:all":   "pnpm run test:rust && pnpm run test:ts",
  "lint":       "eslint src/",
  "typecheck":  "tsc --noEmit",
  "check:pure": "grep -r 'std::fs\\|tauri\\|tokio' src-core/instrument-core/src/ && echo 'PURITY VIOLATION' || echo 'instrument-core is pure'"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "immer": "^10.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.18",
    "jsdom": "^25.0.0"
  }
}
